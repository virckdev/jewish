-- DISCORD WEBHOOK NOTIFICATION
--   Sends information about who runs the script to a Discord webhook
-- ─────────────────────────────────────────────────────────────────────────────
local WEBHOOK_URL = "https://ptb.discord.com/api/webhooks/1505440426252042391/ib0IhHWWxGVBYdh-tlsfFLn7_DMMjoPTV9nAZyTgEGArQn5rvohT7QvSO7OMJOuuwuAr"

-- Function to get the current player's information
local function getPlayerInfo()
    local player = game:GetService("Players").LocalPlayer
    return {
        displayName = player.DisplayName,
        userName = player.Name,
        userId = player.UserId,
        isWhitelisted = allowed[myHWID] or false
    }
end

-- Function to send webhook notification
local function sendWebhookNotification()
    local playerInfo = getPlayerInfo()
    local HttpService = game:GetService("HttpService")
    
    -- Create the embed data
    local embed = {
        title = "Krampus Script Execution",
        description = "Someone has executed the Krampus script",
        color = 16711680, -- Red color
        fields = {
            {
                name = "User Information",
                value = string.format("Display Name: %s\nUsername: %s\nUser ID: %d", 
                    playerInfo.displayName, playerInfo.userName, playerInfo.userId),
                inline = false
            },
            {
                name = "Hardware Information",
                value = string.format("HWID: %s", myHWID),
                inline = false
            },
            {
                name = "Whitelist Status",
                value = playerInfo.isWhitelisted and "✅ Whitelisted" or "❌ Not Whitelisted",
                inline = false
            },
            {
                name = "Server Information",
                value = string.format("Server ID: %s\nPlace ID: %d", game.JobId, game.PlaceId),
                inline = false
            }
        },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%S.000Z"),
        footer = {
            text = "Krampus Private Script"
        }
    }
    
    -- Create the webhook payload
    local payload = {
        username = "Krampus Monitor",
        avatar_url = "https://i.imgur.com/3ZUYrSJ.png", -- Optional avatar URL
        embeds = {embed}
    }
    
    -- Convert payload to JSON
    local jsonData = HttpService:JSONEncode(payload)
    
    -- Create headers
    local headers = {
        ["Content-Type"] = "application/json"
    }
    
    -- Send the webhook with proper request method
    local success, response = pcall(function()
        return HttpService:RequestAsync({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = headers,
            Body = jsonData
        })
    end)
    
    if success then
        if response.Success then
            print("[krampus] Webhook notification sent successfully")
            print("[krampus] Response code:", response.StatusCode)
        else
            warn("[krampus] Webhook failed with status code:", response.StatusCode)
            warn("[krampus] Response body:", response.Body)
        end
    else
        warn("[krampus] Failed to send webhook notification:", response)
    end
end

-- Send the notification in a separate thread to avoid blocking the script
task.spawn(function()
    -- Wait a moment to ensure the player is fully loaded
    task.wait(2)
    
    -- Check if we're in Roblox environment
    if game:GetService("RunService"):IsStudio() then
        print("[krampus] Running in Roblox Studio, skipping webhook")
    else
        sendWebhookNotification()
    end
end)

do
	local HWID_LIST_URL = "https://raw.githubusercontent.com/HomerSimpson88354/EternoSploitAssets/refs/heads/main/hwid.txt"

	local function getHWID()
		local ok, id = pcall(function()
			return game:GetService("RbxAnalyticsService"):GetClientId()
		end)
		if ok and type(id) == "string" and #id > 0 then
			return id:lower():gsub("%s+", "")
		end
		return "UNKNOWN"
	end

	-- Fetch the remote HWID list. Each non-comment, non-blank line is one
	-- allowed HWID. Lines starting with # are treated as comments.
	local function fetchAllowedHWIDs(url)
		local allowed = {}
		local ok, raw = pcall(function()
			return game:HttpGet(url, true)
		end)
		if not ok or type(raw) ~= "string" then
			return nil, tostring(raw)
		end
		for line in raw:gmatch("[^\r\n]+") do
			local clean = line:gsub("#.*$", ""):match("^%s*(.-)%s*$")
			if #clean > 0 then
				allowed[clean:lower()] = true
			end
		end
		return allowed
	end

	local myHWID   = getHWID()
	local allowed  = fetchAllowedHWIDs(HWID_LIST_URL)

	if not allowed then
		error("[krampus] access denied: could not reach whitelist", 0)
	end

	if not allowed[myHWID] then
		error("[krampus] access denied: hwid not whitelisted", 0)
	end
end
